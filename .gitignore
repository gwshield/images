# Note:
# To effectively apply the changes you will have
# to re-index the git index (if there are already
# commited files)
#
# $ git rm -r --cached .
# $ git add .
# $ git commit -m ".gitignore index rebuild"
#

######################################
# Generated build/cache directories
# for package development environment
######################################
.devbox
.venv

# Personal DevBox configuration with MPOWR-IT features
# devbox.json is ignored — contains env vars and potentially secrets (PATs etc.)
# devbox.json.default is the committed template (no secrets)
devbox.json
devbox.json.*
!devbox.json.default
dbx-*.sh

######################################
# CUSTOM
######################################

# Local staging area for files pushed to external repos (e.g. gwshield/images)
# via GitHub API — not part of this repo's source tree.
.staging/

# Draft documents — promoted versions live in meta/docs/internal/
meta/docs/internal/_draft/

######################################
# Hardened-images: scan outputs
# allowlist.yaml is committed; all
# generated report files are ignored.
######################################

# CVE scan reports (Trivy, Grype, etc.)
images/*/*/scan/*.json
images/*/*/scan/*.sarif
images/*/*/scan/*.txt
images/*/*/scan/*.csv
images/*/*/scan/*.xml

# SBOM artifacts
images/*/*/scan/*.sbom.json
images/*/*/scan/*.sbom.spdx
images/*/*/scan/*.sbom.spdx.json
images/*/*/scan/*.cdx.json
images/*/*/scan/*.bom.json

# Provenance / attestation files
images/*/*/scan/*.intoto.jsonl
images/*/*/scan/*.att

# Build cache and intermediate artifacts
images/*/*/build/*.tar
images/*/*/build/*.tar.gz
images/*/*/build/*.zip
/validate.sh
# prevent vault password file to be part of this repo
.vault/

# Platform test artifacts
test-*.dat
test-*.txt
test-*.bin
test-*.log
test-*.json
test-*.gz
test-*.tar
test-*.tar.gz
*.test
*.tmp

# V2 Logger deployment logs
logs/
*.jsonl

######################################
# GENERIC
######################################

###### std ######
.lock
*.log

###### patches/diffs ######
*.patch
*.diff
*.orig
*.rej

###### python bytecode ######
*.pyc
__pycache__/

######################################
# Operating Systems
######################################

###### OSX ######
._*
.DS*
.Spotlight-V100
.Trashes

###### Windows ######
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.shortcut

######################################
# Editors
######################################

###### Sublime ######
*.sublime-workspace
*.sublime-project

###### Eclipse ######
.classpath
.buildpath
.project
.settings/

###### Netbeans ######
/nbproject/

###### Intellij IDE ######
.idea/
.idea_modules/

###### vim ######
*.swp
*.swo
*.swn
*.swm
*~

###### TextMate ######
.tm_properties
*.tmproj

###### BBEdit ######
*.bbprojectd
*.bbproject

######################################
# ADDITIONAL PROJECT RELATED EXCLUDES
######################################

/logs.intern
/local
/cache
/tmp
/temp
node_modules
.env.local
.vault/*
